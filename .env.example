GOOGLE_TOKEN_JSON=
GOOGLE_CREDENTIALS_JSON=
GOOGLE_SHEET_ID=
GOOGLE_SHEET_URL=
GOOGLE_CALENDAR_ID=primary

# OpenAI (for embeddings in Pinecone)
OPENAI_API_KEY=
